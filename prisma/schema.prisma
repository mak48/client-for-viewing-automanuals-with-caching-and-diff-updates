generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int        @id @default(autoincrement())
  name      String
  login     String     @unique
  password  String
  favorites Favorite[]
  manuals   Manual[]
}


model Manual {
  id         Int         @id @default(autoincrement())
  title      String
  carBrand   String
  fileLink   String
  localPath  String?
  fileHash   String?
  chunksHash String?
  version    Int          @default(1)
  uploaderId Int
  uploader   User         @relation(fields: [uploaderId], references: [id])
  favorites  Favorite[]
}

model Favorite {
  userId   Int
  manualId Int
  manual   Manual @relation(fields: [manualId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@id([userId, manualId])
}
